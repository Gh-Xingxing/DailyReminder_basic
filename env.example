# 环境配置文件模板
# 复制此文件为 .env 并填入你的API密钥
# 注意：.env 文件不要上传到GitHub！

# 和风天气API配置
# 获取地址：https://dev.qweather.com/
QWEATHER_HOST=你的和风天气API地址
QWEATHER_KEY=你的和风天气API密钥

# Server酱推送配置
# 获取地址：https://sc3.ft07.com/
SERVERCHAN_KEY=你的Server酱SendKey

# Flask配置（可选配置，没有不需配置）
FLASK_SECRET_KEY=your-secret-key-here
FLASK_DEBUG=True
